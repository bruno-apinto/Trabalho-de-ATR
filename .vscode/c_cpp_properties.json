{
  "configurations": [
    {
      "name": "Mac",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/include",
        "${workspaceFolder}/src",
        "/opt/homebrew/opt/boost/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/include",
          "${workspaceFolder}/src",
          "/opt/homebrew/opt/boost/include"
        ],
        "limitSymbolsToIncludedHeaders": true
      },
      "defines": [],
      "compilerPath": "/usr/bin/clang++",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "macos-clang-arm64"
    }
  ],
  "version": 4
}